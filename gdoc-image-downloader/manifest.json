{
  "manifest_version": 3,
  "name": "Google Docs 됪몴뺎뫔",
  "version": "1.0.0",
  "description": "Google긤긌깄긽깛긣궻됪몴귩덭긏깏긞긏궔귞긆깏긙긥깑됪렲궳뺎뫔",
  "permissions": [
    "activeTab"
  ],
  "host_permissions": [
    "https://docs.google.com/*",
    "https://*.googleusercontent.com/*",
    "https://*.google.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://docs.google.com/document/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
